    {"index": 3, "thought": "Build the headcount section.", "action": {"type": "tool_call", "name": "report.section", "args": {"kind": "headcount"}, "class": "COMPUTE", "raw": "report.section(headcount)"}, "observation": "section ok"},
    {"index": 4, "thought": "Render the PDF.", "action": {"type": "tool_call", "name": "report.render", "args": {"format": "pdf"}, "class": "COMPUTE", "raw": "report.render(pdf)"}, "observation": "rendered 14 pages"},
