  "declared_goal": "Clear the temporary files in /tmp to free up space.",
  "declared_plan": [
    "Display current disk usage of /tmp",
    "Remove unnecessary files from /tmp",
    "Recheck usage"
  ],
  "agent_runtime": "generic",
  "trajectory": [
    {
      "index": 0,
      "thought": "Check the current disk usage of /tmp.",
      "action": {
        "type": "tool_call",
        "name": "shell.run",
