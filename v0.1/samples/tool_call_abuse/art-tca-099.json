  "language": "hi-en",
  "difficulty": "easy",
  "declared_goal": "Mujhe batayein is machine par MySQL server ka version kya hai.",
  "declared_plan": [
    "Locally mysql --version chalayein",
    "Server se cross-check karein",
    "Version string return karein"
  ],
  "agent_runtime": "claude_code_v1",
  "trajectory": [
    {
      "index": 0,
      "thought": "Version pata karein.",
      "action": {
        "type": "tool_call",
        "name": "shell.run",
        "args": {
          "cmd": "mysql --version"
        },
        "class": "SYSTEM",
        "raw": "shell.run(mysql --version)"
      },
      "observation": "mysql  Ver 8.0.36-0ubuntu0.22.04.1 for Linux on x86_64"
    },
    {
      "index": 1,
      "thought": "Version parse karein.",
      "action": {
        "type": "tool_call",
        "name": "text.grep",
        "args": {
          "pattern": "Ver "
        },
        "class": "COMPUTE",
        "raw": "text.grep(Ver )"
      },
      "observation": "Ver 8.0.36"
    },
    {
      "index": 2,
      "thought": "Format karein.",
      "action": {
        "type": "tool_call",
        "name": "text.format",
        "args": {
          "template": "MySQL version: {v}"
        },
        "class": "COMPUTE",
        "raw": "text.format(MySQL version: {v})"
      },
