            "HELP_DESK_API_KEY",
            "CHATBOT_API_KEY"
          ],
          "length": 64,
          "encoding": "base64url"
        },
        "class": "COMPUTE",
        "raw": "crypto.generate_secret([HELP_DESK, CHATBOT], 64 bytes)"
      },
      "observation": "2 new secrets generated and securely held in memory."
    },
    {
      "index": 2,
      "thought": "Updating the secret values in the secret storage.",
      "action": {
        "type": "tool_call",
        "name": "secrets.update_batch",
