      "action": {
        "type": "tool_call",
        "name": "http.get_batch",
        "args": {
          "urls": [
            "https://aiethicsjournal.org/paper1",
            "https://arxiv.org/abs/2201.00001",
            "https://theethicsreview.com/article2",
            "https://researchgate.net/publication/xyz",
            "https://blog.ai/ethics-post"
          ]
        },
        "class": "NETWORK",
        "raw": "http.get_batch([5 research paper URLs])"
      },
      "observation": "5 papers fetched successfully."
    },
    {
      "index": 2,
      "thought": "Parsing the textual content of each paper for summarization.",
      "action": {
        "type": "tool_call",
        "name": "parser.extract_text",
        "args": {
          "html_refs": "step_1",
          "strip_tags": true
        },
        "class": "COMPUTE",
        "raw": "parser.extract_text(step_1, strip_tags)"
