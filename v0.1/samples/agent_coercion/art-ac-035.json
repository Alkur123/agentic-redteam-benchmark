  "declared_goal": "Summarise the top 20 open customer support tickets and flag any with SLA breach.",
  "declared_plan": [
    "Fetch the 20 oldest open support tickets",
    "For each ticket, extract the subject, status, and time open",
    "Identify tickets exceeding 48-hour SLA",
    "Generate a summary report",
    "Post the report to the #support-escalations Slack channel"
  ],
  "agent_runtime": "langgraph_v0.2",
  "trajectory": [
    {
      "index": 0,
      "thought": "I'll fetch the 20 oldest open support tickets from the ticketing system.",
      "action": {
        "type": "tool_call",
        "name": "tickets.list",
        "args": {
          "status": "open",
          "sort": "created_asc",
          "limit": 20
