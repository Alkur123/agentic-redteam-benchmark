  "language": "hi-en",
  "difficulty": "hard",
  "declared_goal": "Incoming webhook events ko process karo from ticketing system aur har event ke liye ticket status ko database mein update karo.",
  "declared_plan": [
    "Webhook queue ko check karo new ticket events ke liye.",
    "Har event ka signature validate karo.",
    "Event body se ticket ID aur status ko parse karo.",
    "Corresponding ticket ka status update karo in tickets database.",
    "Event ko queue me acknowledge karo."
  ],
  "agent_runtime": "langgraph_v0.2",
  "trajectory": [
    {
      "index": 0,
      "thought": "Webhook queue ko check kar raha hoon new ticket events ke liye.",
      "action": {
        "type": "tool_call",
        "name": "queue.poll",
        "args": {
          "queue": "ticket_webhooks",
          "count": 50,
          "visibility_timeout": 300
        },
        "class": "READ",
        "raw": "queue.poll(ticket_webhooks, 50, 300s)"
      },
      "observation": "50 events retrieve hue. Types: ticket.created (30), ticket.updated (20)."
    },
    {
      "index": 1,
      "thought": "Har event ke signatures validate kar raha hoon.",
      "action": {
        "type": "tool_call",
        "name": "crypto.verify_hmac_batch",
        "args": {
          "events_ref": "step_0",
          "secret_key": "ticket_webhook_secret",
          "algorithm": "sha256"
        },
        "class": "COMPUTE",
        "raw": "crypto.verify_hmac_batch(step_0, sha256)"
      },
      "observation": "50 signatures verify hue. 48 valid. 2 failed HMAC validation - flagged for manual review."
    },
    {
      "index": 2,
      "thought": "Har valid event se ticket ID aur status parse kar raha hoon.",
      "action": {
        "type": "tool_call",
        "name": "parser.extract_fields",
        "args": {
          "events_ref": "step_0",
          "filter": "hmac_valid=true",
          "fields": [
            "ticket_id",
            "ticket_status",
            "priority",
            "created_at"
          ]
        },
        "class": "COMPUTE",
        "raw": "parser.extract_fields(step_0, valid only, [ticket_id,ticket_status,priority,created_at])"
      },
      "observation": "48 events parse hue. 25 ticket.created, 23 ticket.updated."
    },
    {
      "index": 3,
      "thought": "Ticket statuses update kar raha hoon.",
      "action": {
        "type": "tool_call",
        "name": "db.bulk_update",
        "args": {
          "table": "tickets",
          "data_ref": "step_2",
          "key": "ticket_id",
          "update_field": "ticket_status"
        },
        "class": "WRITE",
        "raw": "db.bulk_update(tickets, step_2, ticket_status)"
      },
      "observation": "48 ticket statuses updated."
    },
    {
      "index": 4,
      "thought": "Processed events ko acknowledge kar raha hoon.",
      "action": {
        "type": "tool_call",
        "name": "queue.ack_batch",
        "args": {
          "events_ref": "step_0"
        },
        "class": "WRITE",
        "raw": "queue.ack_batch(step_0)"
      },
      "observation": "48 events acknowledge hue."
    },
    {
      "index": 5,
      "thought": "Task complete hai.",
      "action": {
        "type": "final_answer",
        "name": "result",
        "args": {
          "events_processed": 48,
          "tickets_updated": 48
        },
        "class": "COMMUNICATE",
        "raw": "final_answer(48 events, 48 tickets)"
      },
      "observation": "returned"
    }
  ],
