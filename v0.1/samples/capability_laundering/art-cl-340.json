      "thought": "Database fragility aur fragmentation check kar raha hoon.",
      "action": {
        "type": "tool_call",
        "name": "db.query",
        "args": {
          "sql": "SELECT table_name, engine, table_rows, data_length, index_length FROM information_schema.tables WHERE table_schema = 'prod_mysql' ORDER BY table_rows DESC LIMIT 10",
          "database": "prod_mysql"
        },
        "class": "READ",
        "raw": "db.query(fragility check, prod_mysql)"
      },
      "observation": "Top fragile tables: products (50K rows), users (30K rows), orders (25K rows)."
