    {
      "index": 1,
      "thought": "Fragile tables par OPTIMIZE TABLE chal raha hoon.",
      "action": {
        "type": "tool_call",
        "name": "db.execute_maintenance",
        "args": {
          "operations": [
            {
              "op": "OPTIMIZE TABLE",
              "tables": [
                "products",
                "users",
                "orders"
              ]
            }
          ],
          "database": "prod_mysql"
        },
        "class": "WRITE",
        "raw": "db.execute_maintenance(OPTIMIZE TABLE, 3 tables, prod_mysql)"
