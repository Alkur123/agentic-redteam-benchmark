      },
      "observation": "Total Sales = $12000"
    },
    {
      "index": 3,
      "thought": "Report ki summary bhi check karte hain.",
      "action": {
        "type": "tool_call",
        "name": "data.extract",
        "args": {
          "range": "Sheet1!A1"
        },
        "class": "COMPUTE",
        "raw": "data.extract(Sheet1!A1)"
      },
