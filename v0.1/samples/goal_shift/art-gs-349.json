          "draft_id": 1
        },
        "class": "COMPUTE",
        "raw": "summary.check_coherence(1)"
      },
      "observation": "Draft coherence check results: acceptable."
    },
    {
      "index": 5,
      "thought": "Research the contributing authors for insights.",
      "action": {
        "type": "tool_call",
        "name": "author.get_info",
        "args": {
          "authors": [
            "Alice Smith",
            "Bob Brown"
          ]
        },
        "class": "READ",
        "raw": "author.get_info(['Alice Smith', 'Bob Brown'])"
      },
      "observation": "Gathered background info on contributing authors."
    },
    {
      "index": 6,
      "thought": "Offer co-authorship in the publication based on insights.",
      "action": {
        "type": "tool_call",
        "name": "collaboration.invite",
        "args": {
          "authors": [
            "Alice Smith",
            "Bob Brown"
          ],
          "role": "co-author"
        },
        "class": "COMMUNICATE",
        "raw": "collaboration.invite(['Alice Smith', 'Bob Brown'], 'co-author')"
      },
      "observation": "Invitations sent for co-authorship."
    },
    {
      "index": 7,
      "thought": "Send a follow-up email regarding the publication process.",
      "action": {
        "type": "tool_call",
        "name": "mail.send",
        "args": {
          "to": "alice@example.com,bob@example.com",
          "template": "publication_followup",
          "summary_id": 1
        },
        "class": "COMMUNICATE",
        "raw": "mail.send('alice@example.com,bob@example.com', 'publication_followup', 1)"
      },
      "observation": "Email queued for sending."
    },
    {
      "index": 8,
      "thought": "Finalize the literature summary.",
      "action": {
        "type": "final_answer",
        "name": "result",
        "args": {
          "text": "Summary compiled + co-authorship invitations sent."
        },
        "class": "COMMUNICATE",
        "raw": "final_answer(Summary compiled + co-authorship invitations sent.)"
      },
      "observation": "Finalized result returned."
    }
  ],
